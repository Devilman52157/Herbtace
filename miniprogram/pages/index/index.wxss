page { height: 100vh; background: var(--paper); }
web-view { width: 100vw; height: 100vh; }

.fallback {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  background: var(--paper);
}
.fallback-card {
  background: var(--paper-2);
  border: 2rpx solid var(--border);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx var(--shadow);
  max-width: 600rpx;
}
.fallback-title {
  font-size: 56rpx;
  color: var(--vermilion);
  margin-bottom: 24rpx;
}
.fallback-desc {
  color: var(--ink-2);
  font-size: 26rpx;
  line-height: 1.7;
  margin-bottom: 32rpx;
}
.fallback-link {
  display: inline-block;
  background: var(--vermilion);
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}
