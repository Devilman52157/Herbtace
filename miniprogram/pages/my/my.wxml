<view class="tab-shell">
  <view class="my-header">
    <view class="my-avatar">{{settings.name[0] || '养'}}</view>
    <view class="my-body">
      <view class="my-name">{{settings.name || '养生家'}}</view>
      <view class="my-level">积分 {{points}} · 养生 Lv.{{level}}</view>
    </view>
  </view>

  <view class="stats">
    <view class="stat" bindtap="openFull" data-kind="orders">
      <view class="stat-n">{{orders.length}}</view>
      <view class="stat-l">订单</view>
    </view>
    <view class="stat" bindtap="openFull" data-kind="favs">
      <view class="stat-n">{{favs.length}}</view>
      <view class="stat-l">收藏</view>
    </view>
    <view class="stat" bindtap="openFull" data-kind="traces">
      <view class="stat-n">{{traces.length}}</view>
      <view class="stat-l">溯源</view>
    </view>
    <view class="stat" bindtap="openFull" data-kind="chats">
      <view class="stat-n">{{chats.length}}</view>
      <view class="stat-l">问诊</view>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="openFull" data-kind="cart">
      <view class="menu-l">我的购物车</view><view class="menu-r">{{cart.length}} 件 →</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="orders">
      <view class="menu-l">我的订单</view><view class="menu-r">→</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="addrs">
      <view class="menu-l">收货地址</view><view class="menu-r">{{addrs.length}} 个 →</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="traces">
      <view class="menu-l">溯源记录</view><view class="menu-r">→</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="chats">
      <view class="menu-l">问诊记录</view><view class="menu-r">→</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="favs">
      <view class="menu-l">我的收藏</view><view class="menu-r">→</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="points">
      <view class="menu-l">我的积分</view><view class="menu-r">{{points}} →</view>
    </view>
    <view class="menu-item" bindtap="openFull" data-kind="settings">
      <view class="menu-l">设置</view><view class="menu-r">→</view>
    </view>
  </view>
</view>
