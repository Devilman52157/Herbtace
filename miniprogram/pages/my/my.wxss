.tab-shell { min-height: 100vh; padding: 0 0 80rpx; background: var(--paper); }

.my-header {
  background: linear-gradient(135deg, var(--vermilion) 0%, var(--vermilion-2) 100%);
  padding: 80rpx 40rpx 60rpx;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.my-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: var(--gold);
  color: #fff;
  font-size: 48rpx;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Ma Shan Zheng', serif;
}
.my-name { font-size: 36rpx; font-weight: 600; margin-bottom: 6rpx; }
.my-level { font-size: 24rpx; opacity: 0.85; }

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: var(--paper-2);
  margin: -32rpx 32rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 16rpx var(--shadow);
  border: 2rpx solid var(--border);
}
.stat { text-align: center; }
.stat-n { font-size: 40rpx; color: var(--vermilion); font-weight: 600; }
.stat-l { font-size: 24rpx; color: var(--ink-3); margin-top: 4rpx; }

.menu { padding: 0 32rpx; }
.menu-item {
  background: var(--paper-2);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.menu-l { font-size: 28rpx; color: var(--ink); }
.menu-r { font-size: 26rpx; color: var(--ink-3); }
